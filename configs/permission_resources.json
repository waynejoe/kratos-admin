            "apis": ["/v1/permission/resource/save"]
          },
          {
            "type": "button",
            "path": "menu_management:delete",
            "name": "删除",
            "apis": ["/v1/permission/resource/delete"]
          },
          {
            "type": "button",
            "path": "menu_management:import",
            "name": "批量导入",
            "apis": ["/v1/permission/resource/import"]
