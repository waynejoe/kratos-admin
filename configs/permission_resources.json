            "name": "新建团队",
            "apis": ["/v1/permission/group/save"]
          },
          {
            "type": "button",
            "path": "team_management:edit",
            "name": "编辑",
            "apis": ["/v1/permission/group/save"]
          },
          {
            "type": "button",
            "path": "team_management:delete",
            "name": "删除",
            "apis": ["/v1/permission/group/delete"]
          },
          {
            "type": "button",
            "path": "team_management:member_management",
            "name": "成员管理",
            "apis": [
              "/v1/permission/group/member/list",
              "/v1/permission/group/member/save"
            ]
          }
        ]
      },
      {
        "type": "menu",
        "path": "role_management",
